# Mimo AI — 5 system keys buat rotasi (dipisah koma). JANGAN commit key asli.
MIMO_KEYS=sk-aaa,sk-bbb,sk-ccc,sk-ddd,sk-eee

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Anon/public key (dipakai di browser buat auth + cloud save)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key (SERVER ONLY — dipakai buat cache kombinasi)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
